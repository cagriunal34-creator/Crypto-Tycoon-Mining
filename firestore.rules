rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Temel Oturum Kontrolü
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Kesin Yönetici Yetkisi (UID Bazlı Sabitlenmiş)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "Sp073O7nB0Qcc6p3FbcsfZSux1u2" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // Sahip Kontrolü
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Küresel Ayarlar: Herkese açık okuma, sadece Admin yazma
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin(); 
    }
    
    // Kullanıcılar: Sahibi okur/yazar, Admin her şeyi yapar
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin() || isOwner(userId);
      
      // Alt koleksiyonlar için izinler
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // Loncalar: Herkese açık okuma, Admin tam yetki
    match /guilds/{guildId} {
      allow read: if true;
      allow create: if isSignedIn() || isAdmin();
      allow update: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin() || (resource.data.ownerId == request.auth.uid);
    }
    
    // Market: Herkese açık okuma, Admin tam yetki
    match /marketplace/{listingId} {
      allow read: if true;
      allow create: if isSignedIn() || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.sellerId == request.auth.uid);
    }

    // Para Çekme Talepleri: Sadece Admin yönetir, Kullanıcı oluşturur
    match /withdrawals/{withdrawalId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    // Loglar: Sadece Admin
    match /logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
